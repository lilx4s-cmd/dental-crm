# Database — use a cloud Postgres (Neon/Supabase) URL for local dev
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dental_crm?sslmode=require"

PORT=3001
NODE_ENV=development

# JWT — generate secrets with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# S3-compatible storage (MinIO in docker-compose, AWS S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme
S3_BUCKET=dental-crm
S3_FORCE_PATH_STYLE=true

# Supabase storage (file uploads/downloads via signed URLs) and PDF/portal QR links
SUPABASE_URL=https://CHANGE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=dental-crm-files

# AI features (optional — treatment plan summaries, WhatsApp drafts, item suggestions via
# xAI's Grok API). Leave XAI_API_KEY blank to disable these features gracefully.
XAI_API_KEY=
XAI_MODEL=grok-4.5
XAI_BASE_URL=https://api.x.ai/v1

# --- Reserved for future phases (not used in Phase 1) ---
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_API_VERSION=v20.0
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMS_PROVIDER_API_KEY=
